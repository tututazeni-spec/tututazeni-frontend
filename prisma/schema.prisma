generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// CORE / USERS & ORG
//////////////////////////
model User {
  id                      Int                     @id @default(autoincrement())
  fullName                String                  @db.Text
  password                String
  email                   String                  @unique
  roleId                  Int?
  role                    Role?                   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  active                  Boolean                 @default(true)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  unitId                  Int?
  unit                    Unit?                   @relation(fields: [unitId], references: [id])
  profile                 Profile?
  enrollments             Enrollment[]
  questions               Questions[]
  answers                 Answers[]
  performance             PerformanceReview[]
  points                  UserPoints?
  microLearningDispatches MicroLearningDispatch[]
  position                Position?               @relation("PositionUsers", fields: [positionId], references: [id])
  positionId              Int?
  onboardingPlans         OnboardingPlan[]
  reportLogs              ReportLog[]
  badgeAwards             BadgeAward[]
  courseFeedbacks         CourseFeedback[]
  notificationLogs        NotificationLog[]
  auditLogs               AuditLog[]
  successionPlans         SuccessionPlan[]
  assessmentAttempts      AssessmentAttempt[]
  userCompetencies        UserCompetency[]
  developmentPlans        DevelopmentPlan[]
  leadershipPrograms      LeadershipParticipant[]
  articles                KnowledgeArticle[]
  interactions            KnowledgeInteraction[]
  tags                    KnowledgeTag[]
  processStandards        ProcessStandard[]
  processSteps            ProcessStep[]
  trainings               Training[]
  trainingParticipants    TrainingParticipant[]
  careers                 UserCareer[]
  departmentId            Int?
  department              Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  historyRecords          HistoryRecord[]
  mobileSessions          MobileSession[]
  mobileSyncLogs          MobileSyncLog[]
  executiveReports        ExecutiveReport[]
  aiSessions              AiTutorSession[]
  liveAttendances         LiveAttendance[]
  liveMessages            LiveChatMessage[]
  postClassResponses      PostClassResponse[]
  instructorProfile       InstructorProfile?
  instructorReviews       InstructorReview[]
  events                  Event[]
  eventParticipants       EventParticipant[]
}

model Answers {
  id         Int       @id @default(autoincrement())
  body       String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     Int
  questionId Int
  user       User      @relation(fields: [userId], references: [id])
  question   Questions @relation(fields: [questionId], references: [id])
}

model Questions {
  id        Int       @id @default(autoincrement())
  title     String    @db.Text
  body      String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  answers   Answers[]
}

model Profile {
  id     Int    @id @default(autoincrement())
  bio    String @db.Text
  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Unit {
  id                      Int                      @id @default(autoincrement())
  name                    String
  tipo                    String
  province                String?
  users                   User[]
  departmentId            Int?
  department              Department?              @relation("UnitDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  learningPathAssignments LearningPathAssignment[] @relation("UnitLearningPathAssignments")
  operationalMetrics      OperationalMetric[]
}

model Department {
  id                 Int                 @id @default(autoincrement())
  name               String
  createdAt          DateTime            @default(now())
  units              Unit[]              @relation("UnitDepartment")
  users              User[]
  dashboardSnapshots DashboardSnapshot[]
  executiveReports   ExecutiveReport[]

  @@index([name])
}

model DashboardSnapshot {
  id                    Int         @id @default(autoincrement())
  departmentId          Int?
  totalUsers            Int
  totalCoursesCompleted Int
  averageScore          Float
  activePlans           Int
  generatedAt           DateTime    @default(now())
  department            Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([departmentId])
}

model Post {
  id         Int        @id @default(autoincrement())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  title      String     @db.Text
  published  Boolean    @default(false)
  categories Category[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  posts Post[]
}

model GlobalSearchIndex {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  title       String
  description String?  @db.Text
  route       String?
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([title])
}

enum UserRole {
  COLABORADOR
  LIDER
  RH
  ADMIN
}

//////////////////////////
// LEARNING
//////////////////////////
model Course {
  id            Int                  @id @default(autoincrement())
  title         String               @db.Text
  description   String?              @db.Text
  category      String?
  workloadHours Int?
  mandatory     Boolean              @default(false)
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  modules       Module[]
  enrollments   Enrollment[]
  evaluations   Evaluation[]
  competencies  CourseCompetency[]
  learningPaths LearningPathCourse[]
  analytics     CourseAnalytics[]
  feedbacks     CourseFeedback[]
  assessments   Assessment[]
  aiSessions    AiTutorSession[]
  liveClasses   LiveClass[]
}

model LearningPath {
  id          Int                      @id @default(autoincrement())
  title       String                   @db.Text
  description String?                  @db.Text
  mandatory   Boolean                  @default(false)
  createdAt   DateTime                 @default(now())
  courses     LearningPathCourse[]
  assignments LearningPathAssignment[]
}

model LearningPathCourse {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  courseId       Int
  seq            Int
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
}

model LearningPathAssignment {
  id             Int          @id @default(autoincrement())
  learningPathId Int
  unitId         Int?
  role           UserRole?
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  unit           Unit?        @relation("UnitLearningPathAssignments", fields: [unitId], references: [id])
}

model Module {
  id        Int      @id @default(autoincrement())
  courseId  Int
  title     String
  seq       Int
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

model Lesson {
  id          Int               @id @default(autoincrement())
  moduleId    Int
  title       String
  contentType LessonContentType @default(VIDEO)
  videoUrl    String?           @db.Text
  pdfUrl      String?           @db.Text
  seq         Int
  createdAt   DateTime          @default(now())
  module      Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses  LessonProgress[]
}

model Enrollment {
  id          Int                 @id @default(autoincrement())
  userId      Int
  courseId    Int
  status      EnrollmentStatus    @default(EM_ANDAMENTO)
  enrolledAt  DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses  LessonProgress[]
  attempts    EvaluationAttempt[] @relation("EnrollmentAttempts")
  certificate Certificate?
  aiSessions  AiTutorSession[]

  @@index([userId])
  @@index([courseId])
}

model Assessment {
  id                 Int                  @id @default(autoincrement())
  courseId           Int
  title              String
  passScore          Float                @default(70)
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions          AssessmentQuestion[]
  assessmentAttempts AssessmentAttempt[]
}

model AssessmentQuestion {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  question     String     @db.Text
  options      Json
  correctIndex Int
  weight       Float      @default(1)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentAttempt {
  id           Int        @id @default(autoincrement())
  assessmentId Int
  userId       Int
  score        Float
  passed       Boolean
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([userId])
}

model LessonProgress {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  lessonId     Int
  completed    Boolean    @default(false)
  completedAt  DateTime?
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
}

model Evaluation {
  id                 Int                  @id @default(autoincrement())
  courseId           Int
  title              String
  createdAt          DateTime             @default(now())
  question           String               @db.Text
  options            Json
  correctOptionIndex Int
  employeeId         Int
  score              Float
  feedback           String               @db.Text
  evaluatedAt        DateTime
  employee           Employee             @relation(fields: [employeeId], references: [id])
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts           EvaluationAttempt[]
  questions          EvaluationQuestion[]

  @@index([courseId])
}

model EvaluationQuestion {
  id                       Int                       @id @default(autoincrement())
  evaluationId             Int
  question                 String                    @db.Text
  options                  Json
  correctIndex             Int
  evaluation               Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  evaluationAttemptAnswers EvaluationAttemptAnswer[]

  @@index([evaluationId])
}

model EvaluationAttempt {
  id             Int                       @id @default(autoincrement())
  enrollmentId   Int
  validationCode String
  scorePercent   Float?
  passed         Boolean?
  attemptedAt    DateTime                  @default(now())
  startedAt      DateTime                  @default(now())
  finishedAt     DateTime?
  evaluationId   Int
  enrollment     Enrollment                @relation("EnrollmentAttempts", fields: [enrollmentId], references: [id], onDelete: Cascade)
  evaluation     Evaluation                @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  answers        EvaluationAttemptAnswer[]

  @@index([evaluationId])
  @@index([enrollmentId])
}

model EvaluationAttemptAnswer {
  id            Int                @id @default(autoincrement())
  attemptId     Int
  questionId    Int
  selectedIndex Int
  isCorrect     Boolean
  createdAt     DateTime           @default(now())
  attempt       EvaluationAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      EvaluationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}

model Certificate {
  id                Int                @id @default(autoincrement())
  type              CertificateType
  enrollmentId      Int?               @unique
  programId         Int?
  developmentPlanId Int?
  issuedAt          DateTime           @default(now())
  validationCode    String             @unique
  fileUrl           String?            @db.Text
  revoked           Boolean            @default(false)
  enrollment        Enrollment?        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  program           LeadershipProgram? @relation(fields: [programId], references: [id])
  developmentPlan   DevelopmentPlan?   @relation(fields: [developmentPlanId], references: [id])
}

model MicroLearning {
  id        Int                     @id @default(autoincrement())
  title     String
  content   String                  @db.Text
  createdAt DateTime                @default(now())
  dispatch  MicroLearningDispatch[]
  active    Boolean                 @default(true)
}

model MicroLearningDispatch {
  id              Int           @id @default(autoincrement())
  microLearningId Int
  userId          Int
  viewed          Boolean       @default(false)
  microLearning   MicroLearning @relation(fields: [microLearningId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarScript {
  id        Int      @id @default(autoincrement())
  title     String
  script    String   @db.Text
  version   Int      @default(1)
  videoUrl  String?  @db.Text
  createdAt DateTime @default(now())
}

model ContentAsset {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  type        String
  url         String   @db.Text
  version     Int      @default(1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Training {
  id           Int               @id @default(autoincrement())
  title        String
  description  String?           @db.Text
  startDate    DateTime
  endDate      DateTime
  location     String?
  instructorId Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   User              @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  sessions     TrainingSession[]
}

model TrainingSession {
  id           Int                   @id @default(autoincrement())
  trainingId   Int
  sessionDate  DateTime
  duration     Int
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  training     Training              @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  participants TrainingParticipant[]
}

model TrainingParticipant {
  id        Int             @id @default(autoincrement())
  sessionId Int
  userId    Int
  status    String          @default("registered")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LiveClass {
  id             Int                  @id @default(autoincrement())
  courseId       Int
  zoomMeetingId  String?              @db.Text
  topic          String               @db.Text
  scheduledAt    DateTime
  duration       Int
  recordingUrl   String?              @db.Text
  createdAt      DateTime             @default(now())
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances    LiveAttendance[]
  messages       LiveChatMessage[]
  postEvaluation PostClassEvaluation?

  @@index([courseId])
}

model LiveAttendance {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  joinedAt    DateTime
  leftAt      DateTime?
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, userId])
}

model LiveChatMessage {
  id          Int       @id @default(autoincrement())
  liveClassId Int
  userId      Int
  message     String    @db.Text
  createdAt   DateTime  @default(now())
  liveClass   LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveClassId])
}

model PostClassEvaluation {
  id           Int                 @id @default(autoincrement())
  liveClassId  Int                 @unique
  averageScore Float               @default(0)
  liveClass    LiveClass           @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  responses    PostClassResponse[]
}

model PostClassResponse {
  id           Int                 @id @default(autoincrement())
  evaluationId Int
  userId       Int
  rating       Int
  feedback     String?             @db.Text
  createdAt    DateTime            @default(now())
  evaluation   PostClassEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, userId])
}

enum LessonContentType {
  VIDEO
  AVATAR
  PDF
  QUIZ
}

enum CertificateType {
  COURSE
  LEADERSHIP
  DEVELOPMENT
}

enum EnrollmentStatus {
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

//////////////////////////
// HR
//////////////////////////
model Position {
  id              Int              @id @default(autoincrement())
  name            String
  level           String?
  department      String?
  users           User[]           @relation("PositionUsers")
  successionPlans SuccessionPlan[]
}

model PerformanceReview {
  id             Int      @id @default(autoincrement())
  userId         Int
  cycleId        Int
  reviewerId     Int?
  type           String                              // SELF|MANAGER|PEER|R360
  status         String   @default("PENDING_SELF")
  score          Float?
  potentialScore Int?
  feedback       String?
  justification  String?
  category       String?                             // LOW|MEDIUM|HIGH
  submittedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user     User              @relation("ReviewedUser",   fields: [userId],     references: [id])
  reviewer User?             @relation("ReviewerUser",   fields: [reviewerId], references: [id])
  cycle    PerformanceCycle  @relation(fields: [cycleId],references: [id])
  goals            GoalEvaluation[]
  competencyEvals  CompetencyEvaluation[]
  calibrationLogs  CalibrationLog[]
  disputes         PerformanceDispute[]
  @@unique([userId, cycleId, type])
  @@index([userId])
  @@index([status])
}

model CompetencyEvaluation {
  id             Int  @id @default(autoincrement())
  reviewId       Int
  competencyId   Int
  evaluatedLevel Int
  feedback       String?
  review PerformanceReview @relation(fields: [reviewId],     references: [id], onDelete: Cascade)
  @@unique([reviewId, competencyId])
}

model ContinuousFeedback {
  id            Int      @id @default(autoincrement())
  giverId       Int
  userId        Int
  cycleId       Int?
  type          String                               // PRAISE|IMPROVEMENT|GENERAL
  message       String
  visibleToUser Boolean  @default(true)
  createdAt     DateTime @default(now())
  giver User             @relation("FeedbackGiver",    fields: [giverId],  references: [id])
  user  User             @relation("FeedbackReceived", fields: [userId],   references: [id])
  cycle PerformanceCycle?@relation(fields: [cycleId],  references: [id])
  @@index([userId])
}

model CalibrationLog {
  id              Int      @id @default(autoincrement())
  reviewId        Int
  calibratorId    Int
  previousScore   Float?
  calibratedScore Float
  reason          String
  createdAt       DateTime @default(now())
  review     PerformanceReview @relation(fields: [reviewId],      references: [id])
  calibrator User              @relation(fields: [calibratorId],  references: [id])
}

model PerformanceDispute {
  id         Int      @id @default(autoincrement())
  reviewId   Int
  userId     Int
  reason     String
  evidence   String?
  status     String   @default("OPEN")  // OPEN|RESOLVED|REJECTED
  resolution String?
  createdAt  DateTime @default(now())
  review PerformanceReview @relation(fields: [reviewId], references: [id])
  user   User              @relation(fields: [userId],   references: [id])
}

model NineBoxPlacement {
  id              Int      @id @default(autoincrement())
  userId          Int
  cycleId         Int?
  performanceAxis Int                                // 1-3
  potentialAxis   Int                                // 1-3
  justification   String
  updatedById     Int
  updatedAt       DateTime @default(now())
  user  User              @relation(fields: [userId],      references: [id])
  cycle PerformanceCycle? @relation(fields: [cycleId],     references: [id])
  @@unique([userId, cycleId])
}


model PerformanceCycle {
  id                  Int      @id @default(autoincrement())
  name                String
  type                String                        // PROBATION|QUARTERLY|SEMESTER|ANNUAL|AD_HOC
  status              String   @default("PLANNED")  // PLANNED|ACTIVE|CLOSED|CANCELLED
  startDate           DateTime
  endDate             DateTime
  selfEvalDeadline    DateTime?
  managerEvalDeadline DateTime?
  goalsWeight         Int      @default(40)
  competenciesWeight  Int      @default(40)
  behaviorsWeight     Int      @default(20)
  selfBeforeManager   Boolean  @default(true)
  anonymous360        Boolean  @default(true)
  scoreScale          Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  reviews     PerformanceReview[]
  goals       PerformanceGoal[]
  feedback    ContinuousFeedback[]
  nineBox     NineBoxPlacement[]
  @@index([status])
}

model PerformanceGoal {
  id           Int      @id @default(autoincrement())
  userId       Int
  cycleId      Int
  title        String
  description  String?
  targetValue  Float
  currentValue Float    @default(0)
  progress     Int      @default(0)    // 0-100%
  weight       Float    @default(100)
  unit         String?
  status       String   @default("ON_TRACK")
  notes        String?
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user       User             @relation(fields: [userId],   references: [id])
  cycle      PerformanceCycle @relation(fields: [cycleId],  references: [id])
  evaluations GoalEvaluation[]
  @@index([userId])
}

model GoalEvaluation {
  id       Int   @id @default(autoincrement())
  reviewId Int
  goalId   Int
  score    Float
  comment  String?
  review PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  goal   PerformanceGoal   @relation(fields: [goalId],   references: [id])
  @@unique([reviewId, goalId])
}


model SuccessionPlan {
  id                  Int      @id @default(autoincrement())
  criticalPositionId  Int
  candidateId         Int
  readinessLevel      String   // READY_NOW|READY_SOON|NEEDS_DEVELOPMENT
  priority            String   // PRIMARY|SECONDARY|TERTIARY
  matchScore          Float?
  geographicMobility  Boolean  @default(true)
  available           Boolean  @default(true)
  notes               String?
  readinessByDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  criticalPosition CriticalPosition @relation(fields: [criticalPositionId], references: [id], onDelete: Cascade)
  candidate        User             @relation(fields: [candidateId],        references: [id])
  pdi              SuccessionPDI?
  @@unique([criticalPositionId, candidateId])
  @@index([readinessLevel])
  @@index([candidateId])
}

model TalentPool {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  readinessLevel      String
  mentorId            Int?
  notes               String?
  geographicMobility  Boolean  @default(true)
  createdAt           DateTime @default(now())
  user   User  @relation(fields: [userId],   references: [id])
  mentor User? @relation("TalentPoolMentor", fields: [mentorId], references: [id])
}

model SuccessionPDI {
  id                Int      @id @default(autoincrement())
  successionPlanId  Int      @unique
  gaps              String   // JSON
  developmentGoals  String?
  learningPathIds   Int[]
  courseIds         Int[]
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  successionPlan SuccessionPlan @relation(fields: [successionPlanId], references: [id], onDelete: Cascade)
}


model CriticalPosition {
  id                  Int      @id @default(autoincrement())
  positionId          Int      @unique
  businessImpact      String   // LOW|MEDIUM|HIGH|CRITICAL
  replacementTime     String   // IMMEDIATE|SHORT_TERM|MEDIUM_TERM|LONG_TERM
  exitRisk            String   // LOW|MEDIUM|HIGH|CRITICAL
  expectedExitDate    DateTime?
  criticalReason      String?
  keyPersonRisk       Boolean  @default(false)
  minSuccessorsRequired Int    @default(2)
  requiresDocumentation Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  position       Position         @relation(fields: [positionId],  references: [id])
  successionPlans SuccessionPlan[]
  @@index([exitRisk])
  @@index([businessImpact])
}


model OnboardingPlan {
  id        Int      @id @default(autoincrement())
  userId    Int
  tasks     Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Competency {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  category    String @default("HARD_SKILL")
  tags        String[]
  status      String @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userCompetencies   UserCompetency[]
  courses            CourseCompetency[]
  positions          PositionCompetency[]
  proficiencyLevels  ProficiencyLevel[]
  endorsements       CompetencyEndorsement[]
  evolutionLogs      CompetencyEvolutionLog[]
  @@index([category])
  @@index([status])
}

model ProficiencyLevel {
  id           Int    @id @default(autoincrement())
  competencyId Int
  name         String
  value        Int    // 1-5
  description  String?
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  @@unique([competencyId, value])
}



model CourseCompetency {
  id           Int        @id @default(autoincrement())
  courseId     Int
  competencyId Int
